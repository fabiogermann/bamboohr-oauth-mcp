{
  "name": "bamboohr-oauth-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "OAuth-aware adapter around @twentytwokhz/bamboohr-mcp: terminates BambooHR OAuth, encrypts per-user bearer, runs MCP server with per-request credentials.",
  "license": "LGPL-2.1-only",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bamboohr-oauth-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@twentytwokhz/bamboohr-mcp": "1.1.1",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "supertest": "^7.2.2",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  }
}
